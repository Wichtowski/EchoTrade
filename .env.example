# Environment variables for EchoTrade
# Copy to .env and fill in real values

# --- Database ---
ECHO_DATABASE_URL=postgresql+asyncpg://echo:echo@localhost:5432/echotrade

# --- Docker Host Port Bindings ---
ECHO_HTTP_PORT=80
ECHO_HTTPS_PORT=443
ECHO_POSTGRES_PORT=5432
ECHO_RABBITMQ_PORT=5672
ECHO_RABBITMQ_ADMIN_PORT=15672
ECHO_REDIS_PORT=6379
ECHO_MONGO_PORT=27017
ECHO_CORE_PORT=8000
ECHO_N8N_PORT=5678
ECHO_MAIL_PORT_25=25
ECHO_MAIL_PORT_587=587
ECHO_MAIL_PORT_143=143
ECHO_MAIL_PORT_993=993

# --- Celery / RabbitMQ ---
ECHO_CELERY_BROKER_URL=amqp://echo:echo@localhost:5672//
ECHO_CELERY_RESULT_BACKEND=db+postgresql://echo:echo@localhost:5432/echotrade
ECHO_REDIS_URL=redis://localhost:6379/0
ECHO_MONGODB_URL=mongodb://localhost:27017
ECHO_MONGODB_DATABASE=echotrade

# --- Discord webhooks ---
ECHO_DISCORD_WEBHOOK_DAILY=
ECHO_DISCORD_WEBHOOK_ALERTS=
ECHO_DISCORD_WEBHOOK_PROPOSALS=
ECHO_DISCORD_WEBHOOK_EXECUTIONS=
ECHO_DISCORD_WEBHOOK_RISK=
ECHO_DISCORD_WEBHOOK_JOURNAL=
ECHO_DISCORD_WEBHOOK_OVERRIDE=

# --- Market data ---
ECHO_TWELVE_DATA_API_KEY=

# --- Broker ---
ECHO_BROKER_API_KEY=
ECHO_BROKER_API_SECRET=
ECHO_BROKER_BASE_URL=

# --- LLM ---
ECHO_OPENAI_API_KEY=
ECHO_ANTHROPIC_API_KEY=

# --- Frontend / API ---
ECHO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ECHO_PUBLIC_APP_URL=http://localhost:3000

# --- Auth ---
ECHO_INTERNAL_API_TOKEN=replace-with-long-random-internal-token
ECHO_AUTH_COOKIE_SECURE=false
ECHO_AUTOMATION_USER_ID=
ECHO_APP_VERSION=dev

# --- n8n public route auth ---
N8N_BASIC_AUTH_HASH=

# --- SMTP / Invite delivery ---
ECHO_MAIL_HOSTNAME=mail
ECHO_MAIL_DOMAIN=oskarwichtowski.com
ECHO_SMTP_HOST=
ECHO_SMTP_PORT=587
ECHO_SMTP_USERNAME=
ECHO_SMTP_PASSWORD=
ECHO_SMTP_FROM_EMAIL=
ECHO_SMTP_FROM_NAME=EchoTrade
ECHO_SMTP_STARTTLS=true
ECHO_SMTP_SSL=false

# --- Risk defaults ---
ECHO_MAX_MONTHLY_BUDGET=300
ECHO_MAX_SINGLE_TRADE=75
ECHO_MAX_DAILY_TRADES=2
ECHO_MAX_DAILY_LOSS_PCT=3.0
ECHO_MAX_MONTHLY_LOSS_PCT=15.0
ECHO_COOLDOWN_AFTER_TRADE_HOURS=24
ECHO_COOLDOWN_AFTER_LOSS_HOURS=72


CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT_NAME=
